{
  "name": "Test-Yoga",
  "description": "Taking Home test from madeinindonesia",
  "version": "0.1.0",
  "license": "UNLICENSED",
  "type": "module",
  "sideEffects": [
    "*.css"
  ],
  "scripts": {
    "dev": "bun ./lib/scripts/dev.ts",
    "dev:https": "bun ./lib/scripts/dev.ts --https",
    "build": "bun run setup:styles && next build",
    "start": "next start",
    "preview": "bun run build && next start",
    "check": "biome check && tsgo --noEmit && bun test",
    "clean": "rm -rf .next node_modules/.cache",
    "lint": "biome lint --max-diagnostics=200",
    "lint:fix": "biome lint --write --unsafe --max-diagnostics=200",
    "format": "biome format --write .",
    "typecheck": "tsgo --noEmit",
    "typecheck:tsc": "tsc --noEmit --incremental false --stableTypeOrdering",
    "typecheck:compare": "bun run typecheck:tsc && bun run typecheck",
    "deslop": "deslop",
    "analyze": "ANALYZE=true bun run build",
    "analyze:experimental": "next experimental-analyze",
    "dev:inspect": "bun ./lib/scripts/dev.ts --inspect",
    "lighthouse": "bunx @unlighthouse/cli --site http://localhost:3000",
    "test": "bun test",
    "setup:styles": "bun ./lib/styles/scripts/setup-styles.ts",
    "generate:manifest": "bun ./lib/scripts/generate-manifest.ts",
    "manifest:check": "bun ./lib/scripts/generate-manifest.ts --check"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@gsap/react": "^2.1.2",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@theatre/core": "^0.7.2",
    "@vercel/analytics": "^2.0.1",
    "clsx": "^2.1.1",
    "gsap": "^3.15.0",
    "hamo": "1.0.0-dev.13",
    "lenis": "^1.3.23",
    "next": "16.2.9",
    "next-view-transitions": "^0.3.5",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "tempus": "1.0.0-dev.17",
    "three": "0.184.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.0",
    "@clack/prompts": "^1.5.0",
    "@csstools/postcss-global-data": "^4.0.0",
    "@happy-dom/global-registrator": "^20.10.2",
    "@next/bundle-analyzer": "16.2.9",
    "@svgr/webpack": "^8.1.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@tailwindcss/vite": "^4.3.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@theatre/studio": "^0.7.2",
    "@types/bun": "^1.3.14",
    "@types/node": "^25.9.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.184.0",
    "@typescript/native-preview": "7.0.0-dev.20260609.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "deslop-cli": "0.0.17",
    "happy-dom": "^20.10.2",
    "lefthook": "^2.1.9",
    "postcss-functions": "^4.0.2",
    "postcss-preset-env": "^11.3.0",
    "react-scan": "^0.5.7",
    "tailwindcss": "^4.3.0",
    "ts-morph": "^28.0.0",
    "typescript": "^6.0.3"
  },
  "trustedDependencies": [
    "@biomejs/biome",
    "@swc/core",
    "@tailwindcss/oxide",
    "esbuild",
    "lefthook",
    "sharp"
  ],
  "overrides": {
    "lodash": "^4.17.21",
    "lodash-es": "^4.17.21"
  },
  "packageManager": "bun@1.3.5",
  "private": true
}
